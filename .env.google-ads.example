# ==========================================
# AutoAds 环境变量配置
# ==========================================

# ... 其他现有配置 ...

# ==========================================
# Google Ads MCC 统一授权配置
# ==========================================

# Google OAuth 重定向 URI
# 必须与 Google Cloud Console 中配置的授权重定向 URI 一致
GOOGLE_ADS_OAUTH_REDIRECT_URI=http://localhost:3000/api/google-ads/oauth/callback

# MCC OAuth 回调 URI（管理员授权）
GOOGLE_ADS_MCC_CALLBACK_URI=http://localhost:3000/api/admin/google-ads-mcc/callback

# State Token 加密密钥（用于 OAuth 状态验证）
# 生产环境请使用强随机字符串（至少 32 字符）
GOOGLE_ADS_STATE_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Google Ads API 配置
GOOGLE_ADS_API_VERSION=v15
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Google Cloud OAuth 配置（可选，如果使用统一的 OAuth Client）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
